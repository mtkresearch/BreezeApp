<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/spacing_medium"
    android:paddingTop="@dimen/spacing_tiny"
    android:paddingBottom="@dimen/spacing_tiny">

    <!-- Message Card - grows with content, aligned to left -->
    <androidx.cardview.widget.CardView
        android:id="@+id/assistantMessageCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/ai_message_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:cardUseCompatPadding="false"
        app:contentPadding="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/message_max_width">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <TextView
                android:id="@+id/assistantMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito"
                android:textColor="@color/ai_message_text"
                android:textSize="@dimen/text_size_subtitle"
                tools:text="I'm your AI assistant. I can provide information on AI, machine learning, and many other topics. How can I help you today?" />

            <ProgressBar
                android:id="@+id/typingIndicator"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="@dimen/spacing_small"
                android:indeterminateTint="@color/primary"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Timestamp below message -->
    <TextView
        android:id="@+id/messageTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="2dp"
        android:alpha="0.6"
        android:fontFamily="@font/nunito"
        android:textAppearance="@style/TextAppearance.App.Caption"
        android:textSize="9sp"
        app:layout_constraintStart_toStartOf="@+id/assistantMessageCard"
        app:layout_constraintTop_toBottomOf="@+id/assistantMessageCard"
        tools:text="10:31 AM" />

</androidx.constraintlayout.widget.ConstraintLayout> 
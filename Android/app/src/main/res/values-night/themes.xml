<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark theme -->
    <style name="Theme.BreezeApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors (slightly brightened for dark theme) -->
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorSecondaryVariant">@color/primary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorOnSurface">@color/white</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="android:windowBackground">#121212</item>
        
        <!-- Text colors -->
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#B3FFFFFF</item> <!-- 70% white -->
        <item name="android:textColorHint">#80FFFFFF</item> <!-- 50% white -->
    
        <!-- Font family and text appearances -->
        <item name="android:fontFamily">@font/nunito</item>
        <item name="fontFamily">@font/nunito</item>
        
        <!-- Material text appearances -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.App.Headline1.Dark</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.App.Headline2.Dark</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.App.Headline3.Dark</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.App.Headline4.Dark</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.App.Headline5.Dark</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.App.Headline6.Dark</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.App.Subtitle1.Dark</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.App.Subtitle2.Dark</item>
        <item name="textAppearanceBody1">@style/TextAppearance.App.Body1.Dark</item>
        <item name="textAppearanceBody2">@style/TextAppearance.App.Body2.Dark</item>
        <item name="textAppearanceButton">@style/TextAppearance.App.Button.Dark</item>
        <item name="textAppearanceCaption">@style/TextAppearance.App.Caption.Dark</item>
        <item name="textAppearanceOverline">@style/TextAppearance.App.Overline.Dark</item>
        
        <!-- Material Components customization -->
        <item name="materialButtonStyle">@style/Widget.App.Button.Dark</item>
        <item name="textInputStyle">@style/Widget.App.TextInputLayout.Dark</item>
        <item name="materialCardViewStyle">@style/Widget.App.CardView.Dark</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary</item>
        
        <!-- Make edges rounded for all buttons -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.App.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.LargeComponent</item>
    </style>
</resources> 